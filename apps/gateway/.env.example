# Gateway
# ENVIRONMENT=production makes the gateway FAIL TO START on a default/weak
# JWT_SECRET (< 32 chars or a known placeholder). Keep "development" locally.
ENVIRONMENT=development
REDIS_URL=redis://redis:6379
# In production set a unique, high-entropy secret of >= 32 chars. This signs JWTs.
JWT_SECRET=change-me-in-production-secret-key
# Comma-separated PREVIOUS signing secrets, honoured during a rotation grace
# window so rotating JWT_SECRET does not 401 every in-flight token.
JWT_PREVIOUS_SECRETS=
# Data-at-rest encryption key for the token vault + provider API keys, kept
# SEPARATE from JWT_SECRET (DB4). Empty falls back to JWT_SECRET for back-compat.
ENCRYPTION_SECRET=
ENCRYPTION_PREVIOUS_SECRETS=
# DB1: the credential-free POST /api/auth/token endpoint is OFF by default; the
# supported path to a token is POST /api/users/login. Set true only for a
# dev/pilot — even then it refuses privileged roles (admin, vp_risk).
ALLOW_INSECURE_TOKEN_ENDPOINT=false
# DB5: HMAC key for the hash-chained audit log — SEPARATE from JWT_SECRET so
# rotating one does not break the other's chain. Empty falls back to JWT_SECRET.
# ⛔ Source from KMS/HSM in production; never rotate without re-signing the chain.
AUDIT_HMAC_KEY=
JWT_ISSUER=pii-gateway
JWT_AUDIENCE=pii-gateway-clients
JWT_TTL_HOURS=4
ALLOWED_ORIGINS=http://localhost:3000

# DB6: User database. Unset = SQLite at DB_PATH (development/CI only).
# Production: set to a managed Postgres connection string.
# ⛔ Halt-point: wire RLS + HA topology before going to production.
# Example: DATABASE_URL=postgresql+psycopg2://user:pass@host:5432/vaultex
DATABASE_URL=
# DB_PATH is ignored when DATABASE_URL is set.
DB_PATH=/data/users.db

# UI (Next.js)
NEXT_PUBLIC_GATEWAY_URL=http://localhost:8000
# NEXT_PUBLIC_JWT_SECRET is no longer needed — JWTs are server-issued via POST /api/auth/token
