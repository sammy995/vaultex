{
  "name": "@clawwarden/integrations",
  "version": "0.1.0",
  "description": "Observability & IAM adapters for the ClawWarden stack — OpenTelemetry, Prometheus, Datadog, SIEM (syslog/Splunk HEC), OIDC. Dependency-light.",
  "license": "Apache-2.0",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": { "types": "./dist/index.d.ts", "default": "./dist/index.js" }
  },
  "files": ["dist"],
  "keywords": ["opentelemetry", "prometheus", "datadog", "siem", "splunk", "oidc", "observability"],
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "test": "vitest run --pool=forks"
  },
  "devDependencies": {
    "typescript": "^5.6.0",
    "vitest": "^2.1.0"
  }
}
